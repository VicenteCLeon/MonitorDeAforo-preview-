# Copia este archivo como .env y rellena los valores reales
# NO subas .env a git (ya está en .gitignore)

# ── Seguridad ──────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIA-ESTO-EN-PRODUCCION

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── CORS ───────────────────────────────────────────────────────────────────
# En desarrollo: http://localhost:5173
# En producción: https://tu-dominio.cl
ALLOWED_ORIGINS=http://localhost:5173

# ── Alertas por email (SMTP) ───────────────────────────────────────────────
# Si no configuras esto, las alertas quedan desactivadas (el resto funciona igual)
#
# Gmail: usa una "Contraseña de aplicación" (no tu contraseña normal)
#   → https://myaccount.google.com/apppasswords
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ALERT_FROM=tu-cuenta@gmail.com
# Separa múltiples destinatarios con coma
ALERT_RECIPIENTS=responsable@mail.pucv.cl,otro@mail.pucv.cl
